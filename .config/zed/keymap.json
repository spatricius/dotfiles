[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-s": "workspace::Save",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-shift-h": "workspace::MovePaneLeft",
      "ctrl-shift-l": "workspace::MovePaneRight",
      "ctrl-shift-j": "workspace::MovePaneDown",
      "ctrl-shift-k": "workspace::MovePaneUp",
      "\\": "project_panel::ToggleFocus",
      "space s w": "pane::DeploySearch",
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-f": "buffer_search::Deploy", // vim default: page down
      "alt-h": "pane::ActivatePreviousItem",
      "alt-l": "pane::ActivateNextItem",
      "f5": "debug_panel::ToggleFocus",
      "f7": "debugger::StepInto",
      "f8": "debugger::StepOver",
      "f9": "debugger::Continue",
      "f10": "debugger::StepOut",
    },
  },
  {
    "context": "Editor && !menu",
    "bindings": {
      "ctrl-f": "buffer_search::Deploy", // vim default: page down
      "ctrl-c": "editor::Copy", // vim default: return to normal mode
      "ctrl-x": "editor::Cut", // vim default: decrement
      "ctrl-v": "editor::Paste", // vim default: visual block mode
      "ctrl-shift-v": "editor::Paste",
      "ctrl-s": "workspace::Save", // vim default: show signature
      "alt-j": "editor::MoveLineDown",
      "alt-k": "editor::MoveLineUp",
      "alt-h": "pane::ActivatePreviousItem",
      "alt-l": "pane::ActivateNextItem",
      "f5": "debug_panel::Toggle",
      "f7": "debugger::StepInto",
      "f8": "debugger::StepOver",
      "f9": "debugger::Continue",
      "f10": "debugger::StepOut",
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "space q": "diagnostics::Deploy",
      "space f": "editor::Format",
      "space space": "tab_switcher::Toggle",
      "space /": "buffer_search::Deploy",
      "space g g": "git_panel::ToggleFocus",
      "space g b": "git::Blame",
      "space s f": "file_finder::Toggle",
      "space s d": "diagnostics::Deploy",
      "space s c": "command_palette::Toggle",
      "space b": "editor::ToggleBreakpoint",
      "g r d": "editor::GoToDefinition",
      "g r r": "editor::FindAllReferences",
      "g r a": "editor::ToggleCodeActions",
      "g r n": "editor::Rename",
      "g r i": "editor::GoToImplementation",
      "g r t": "editor::GoToTypeDefinition",
    },
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      "alt-j": "editor::MoveLineDown",
      "alt-k": "editor::MoveLineUp",
      "space f": "editor::FormatSelections",
    },
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
    },
  },
  {
    "context": "Dock",
    "bindings": {
      "\\": "project_panel::Toggle",
    },
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "unbind": {
      "space s": "outline::Toggle",
    },
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "unbind": {
      "y": "vim::HelixYank",
    },
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "unbind": {
      "shift-p": [
        "vim::HelixPaste",
        {
          "before": true,
        },
      ],
    },
  },
  {
    "context": "Picker > Editor",
    "unbind": {
      "ctrl-h": "editor::Backspace",
    },
  },
  {
    "context": "vim_mode == literal",
    "unbind": {
      "ctrl-h": ["vim::Literal", ["ctrl-h", "\b"]],
    },
  },
  {
    "context": "Editor && mode == full",
    "unbind": {
      "ctrl-h": "buffer_search::DeployReplace",
    },
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-h": "pane::SplitLeft",
    },
  },
  {
    "context": "BufferSearchBar",
    "unbind": {
      "ctrl-h": "search::ToggleReplace",
    },
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-h": "pane::SplitLeft",
    },
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-h": "pane::SplitLeft",
    },
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-h": "pane::SplitLeft",
    },
  },
  {
    "context": "VimControl && !menu",
    "unbind": {
      "ctrl-j": "vim::Down",
    },
  },
  {
    "context": "vim_mode == literal",
    "unbind": {
      "ctrl-j": ["vim::Literal", ["ctrl-j", "\n"]],
    },
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w ctrl-j": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-shift-j": "editor::JoinLines",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-k ctrl-j": "editor::UnfoldAll",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-alt-j": "multi_workspace::ToggleWorkspaceSidebar",
    },
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-j": "pane::SplitDown",
    },
  },
  {
    "context": "vim_mode == literal",
    "unbind": {
      "ctrl-l": ["vim::Literal", ["ctrl-l", "\f"]],
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-l": "editor::SelectLine",
    },
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-l": "pane::SplitRight",
    },
  },
  {
    "context": "BufferSearchBar",
    "unbind": {
      "ctrl-l": "search::ToggleSelection",
    },
  },
  {
    "context": "vim_mode == literal",
    "unbind": {
      "ctrl-k": ["vim::Literal", ["ctrl-k", "\u000b"]],
    },
  },
  {
    "context": "vim_mode == insert",
    "unbind": {
      "ctrl-k": ["vim::PushDigraph", {}],
    },
  },
  {
    "context": "vim_mode == replace",
    "unbind": {
      "ctrl-k": ["vim::PushDigraph", {}],
    },
  },
  {
    "context": "vim_mode == waiting",
    "unbind": {
      "ctrl-k": ["vim::PushDigraph", {}],
    },
  },
  {
    "context": "KeymapEditor",
    "unbind": {
      "ctrl-k": "keymap_editor::OpenCreateKeybindingModal",
    },
  },
  {
    "context": "FileFinder || FileFinder > Picker > Editor || FileFinder > Picker > menu",
    "unbind": {
      "ctrl-k": "pane::SplitUp",
    },
  },
  {
    "context": "RecentProjects || RecentProjects > Picker > Editor",
    "unbind": {
      "ctrl-k": "recent_projects::ToggleActionsMenu",
    },
  },
  {
    "context": "RecentProjects || RecentProjects > Picker > Editor",
    "unbind": {
      "ctrl-k": "recent_projects::ToggleActionsMenu",
    },
  },
]
